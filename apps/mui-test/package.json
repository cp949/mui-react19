{
  "name": "mui-test",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @cp949/mui-react19 build",
    "dev": "vite",
    "prebuild": "pnpm --filter @cp949/mui-react19 build",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "precheck-types": "pnpm --filter @cp949/mui-react19 build",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "pretest": "pnpm --filter @cp949/mui-react19 build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cp949/mui-react19": "workspace:*",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cp949/web-logger": "^1.0.5",
    "@repo/typescript-config": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "happy-dom": "^20.10.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
