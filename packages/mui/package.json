{
  "name": "@cp949/mui-react19",
  "version": "1.0.0",
  "description": "React UI components and hooks built on MUI (Material-UI)",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "README.file-drop.md"
  ],
  "scripts": {
    "build": "tsup --clean",
    "dev": "npm run build -- --watch",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "tsc --pretty --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "prepack": "pnpm build",
    "publish:npm": "npm publish"
  },
  "dependencies": {
    "lodash.throttle": "^4.1.1"
  },
  "devDependencies": {
    "@mui/material": "^7.3.6",
    "@mui/system": "^7.3.6",
    "@types/lodash.throttle": "^4.1.9",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.0.16",
    "clsx": "^2.1.1",
    "eslint": "^9.39.2",
    "happy-dom": "^20.0.11",
    "react": "^19.2.3",
    "rxjs": "^7.8.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "peerDependencies": {
    "@mui/material": "^7",
    "@mui/system": "^7",
    "clsx": "^2",
    "react": "^18 || ^19",
    "rxjs": "^7"
  },
  "author": "jjfive",
  "homepage": "https://github.com/cp949/mui-react19#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cp949/mui-react19.git"
  },
  "bugs": {
    "url": "https://github.com/cp949/mui-react19/issues"
  },
  "keywords": [
    "react",
    "hooks",
    "mui",
    "material-ui",
    "components",
    "file-drop"
  ],
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./hooks": {
      "require": {
        "types": "./dist/hooks/index.d.cts",
        "default": "./dist/hooks/index.cjs"
      },
      "import": {
        "types": "./dist/hooks/index.d.ts",
        "default": "./dist/hooks/index.js"
      }
    },
    "./helper": {
      "require": {
        "types": "./dist/helper/index.d.cts",
        "default": "./dist/helper/index.cjs"
      },
      "import": {
        "types": "./dist/helper/index.d.ts",
        "default": "./dist/helper/index.js"
      }
    },
    "./file-drop": {
      "require": {
        "types": "./dist/file-drop/index.d.cts",
        "default": "./dist/file-drop/index.cjs"
      },
      "import": {
        "types": "./dist/file-drop/index.d.ts",
        "default": "./dist/file-drop/index.js"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
