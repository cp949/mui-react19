{
  "name": "@cp949/mui-react19",
  "version": "2.0.0",
  "description": "React UI components and hooks built on MUI (Material-UI)",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "README.file-drop.md"
  ],
  "scripts": {
    "build": "tsup --clean",
    "dev": "tsup --clean --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check-types": "tsc --pretty --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "prepack": "pnpm build",
    "publish:npm": "npm publish"
  },
  "dependencies": {
    "lodash.throttle": "^4.1.1"
  },
  "devDependencies": {
    "@mui/material": "^9.0.0",
    "@mui/system": "^9.0.0",
    "@types/lodash.throttle": "^4.1.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.4",
    "clsx": "^2.1.1",
    "happy-dom": "^20.8.9",
    "react": "^19.2.5",
    "rxjs": "^7.8.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@mui/material": "^9",
    "@mui/system": "^9",
    "clsx": "^2",
    "react": "^18 || ^19",
    "rxjs": "^7"
  },
  "author": "jjfive",
  "homepage": "https://github.com/cp949/mui-react19#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cp949/mui-react19.git"
  },
  "bugs": {
    "url": "https://github.com/cp949/mui-react19/issues"
  },
  "keywords": [
    "react",
    "hooks",
    "mui",
    "material-ui",
    "components",
    "file-drop"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "require": "./dist/hooks/index.cjs",
      "import": "./dist/hooks/index.js"
    },
    "./helper": {
      "types": "./dist/helper/index.d.ts",
      "require": "./dist/helper/index.cjs",
      "import": "./dist/helper/index.js"
    },
    "./file-drop": {
      "types": "./dist/file-drop/index.d.ts",
      "require": "./dist/file-drop/index.cjs",
      "import": "./dist/file-drop/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "hooks": [
        "./dist/hooks/index.d.ts"
      ],
      "helper": [
        "./dist/helper/index.d.ts"
      ],
      "file-drop": [
        "./dist/file-drop/index.d.ts"
      ],
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
